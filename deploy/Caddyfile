# jobfitr — Caddy reverse proxy + static server + auto-HTTPS.
# Installed to /etc/caddy/Caddyfile by bootstrap.sh. Caddy obtains and renews a
# Let's Encrypt cert for jobfitr.app automatically once DNS points at this box.
#
# Same-origin by design: Caddy serves the static front end from web/ and proxies
# only /api/* to the local uvicorn process — so the browser never makes a
# cross-origin request and there is no CORS to configure.

jobfitr.app {
	encode gzip zstd

	# API → the local app server (uvicorn, bound to loopback only).
	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	# Everything else → the static front end.
	handle {
		root * /opt/jobfitr/jobfitr/web
		file_server
	}
}
# Access logs go to journald by default (journalctl -u caddy) — no custom file,
# which the caddy systemd sandbox blocks under /var/log.

# Send www → apex (the www CNAME already resolves here).
www.jobfitr.app {
	redir https://jobfitr.app{uri} permanent
}
