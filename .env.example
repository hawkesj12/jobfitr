# jobfitr — API-key template. Copy to .env and fill in real values:
#     cp .env.example .env
# .env is gitignored; this template is committed so the pattern is documented.
# The free no-key boards run without any of these; the two keyed sources below
# just broaden coverage (Adzuna = general market, USAJOBS = US federal).

# Adzuna — free key from https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJOBS — free key from https://developer.usajobs.gov/apirequest/
# USAJOBS_EMAIL is the email you registered with (sent as the User-Agent).
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional — LLM semantic re-ranking via OpenRouter (OpenAI-compatible).
# Requires an `llm:` block in web-harvest.yaml pointing at OpenRouter:
#   llm:
#     enabled: true
#     provider: openai                       # non-anthropic → OpenAI-compatible path
#     base_url: https://openrouter.ai/api/v1
#     api_key_env: OPENROUTER_API_KEY
#     model: anthropic/claude-haiku-4.5      # any OpenRouter model slug
# OPENROUTER_API_KEY=
